  "keyFeatures": [
    "Client management with health records and consent tracking",
    "Appointment scheduling with multi-artist calendar",
    "Artist portfolio management with image categorization",
    "Financial tracking with commission calculation",
    "Inventory management with stock alerts",
    "Role-based access control with three user types",
    "Automatic database backups",
    "Dark and light theme support"
  ],
  "publicApiSurface": [
    "Client model with contact info, health data, and preferences",
    "Artist model with commission rates and portfolio",
    "TattooSession model with scheduling and pricing",
    "Transaction model with payment tracking",
    "Product model for inventory management",
    "PortfolioItem model with metadata and associations",
    "User model with role-based authentication",
    "Authentication service (hash_password, verify_password, authenticate)",
    "Permissions service (RBAC with can, enforce, elevate_for)",
    "Backup service (create_backup_now, restore_backup, list_backups)",
    "Session management (get_session, begin_session, complete_session)"
  ]
}
